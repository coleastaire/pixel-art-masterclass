# ──────────────────────────────────────────────────────────────
# Pixel Art for Games — Masterclass · .gitignore
# ──────────────────────────────────────────────────────────────
# Personal progress & assets are intentionally NOT ignored, so a
# personal branch off `main` can carry your own work — e.g.:
#     submissions/         your graded assignment artwork
#     assets/              your sprites, palettes, references
#     progress.json / *.md your progress notes
# Only OS, editor, and build/dependency clutter is excluded below.
# ──────────────────────────────────────────────────────────────

# macOS
.DS_Store
.DS_Store?
._*
.AppleDouble
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.directory

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Logs & temp
*.log
npm-debug.log*
*.tmp
.cache/

# Dependencies / build output (forward-looking, if tooling is added later)
node_modules/
dist/
build/
.parcel-cache/

# Python (in case helper/build scripts ever live in-repo)
__pycache__/
*.pyc
.venv/
venv/

# Environment / secrets
.env
.env.*
!.env.example
